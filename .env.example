# ══════════════════════════════════════════════════════════════════
#  KenexAI  │  Environment Variables
# ══════════════════════════════════════════════════════════════════
#
#  Copy this file to  .env  and fill in your values:
#      cp .env.example .env
#

# Google Gemini API Key (for GenAI retention agent)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL (optional — only needed if using Docker DB)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=churn_db
DB_USER=postgres
DB_PASSWORD=postgres
